<odoo>
    <template id="s_contact_us_custom" name="Custom Contact Us">
        <section class="s_contact_us_custom pt80 pb80 bg-200">
            <div class="container">
                <div class="row align-items-stretch g-4">
                    <div class="col-lg-5">
                        <div class="h-100 bg-primary p-5 text-white rounded-3 shadow">
                            <h2 class="fw-bold mb-4">Get in Touch</h2>
                            <p class="mb-5">Have a question about **My Odoo Pro**? We'd love to hear from you. Send us a message and we'll respond as soon as possible.</p>
                            
                            <div class="d-flex mb-4">
                                <i class="fa fa-map-marker fa-2x me-3"></i>
                                <div>
                                    <h5 class="fw-bold mb-0">Our Location</h5>
                                    <p class="mb-0">Dhaka, Bangladesh</p>
                                </div>
                            </div>
                            
                            <div class="d-flex mb-4">
                                <i class="fa fa-phone fa-2x me-3"></i>
                                <div>
                                    <h5 class="fw-bold mb-0">Phone Number</h5>
                                    <p class="mb-0">+880 1XXX-XXXXXX</p>
                                </div>
                            </div>
                            
                            <div class="d-flex">
                                <i class="fa fa-envelope fa-2x me-3"></i>
                                <div>
                                    <h5 class="fw-bold mb-0">Email Address</h5>
                                    <p class="mb-0">info@myodoopro.com</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="col-lg-7">
                        <div class="bg-white p-5 rounded-3 shadow h-100">
                            <form action="/contactus" method="post" class="s_website_form" enctype="multipart/form-data">
                                <div class="row">
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Your Name</label>
                                        <input type="text" class="form-control form-control-lg bg-light border-0" placeholder="Aronno Chowdhury"/>
                                    </div>
                                    <div class="col-md-6 mb-3">
                                        <label class="form-label fw-bold">Email</label>
                                        <input type="email" class="form-control form-control-lg bg-light border-0" placeholder="name@example.com"/>
                                    </div>
                                    <div class="col-12 mb-3">
                                        <label class="form-label fw-bold">Subject</label>
                                        <input type="text" class="form-control form-control-lg bg-light border-0" placeholder="Property Inquiry"/>
                                    </div>
                                    <div class="col-12 mb-4">
                                        <label class="form-label fw-bold">Message</label>
                                        <textarea class="form-control form-control-lg bg-light border-0" rows="4" placeholder="How can My Odoo Pro help you?"></textarea>
                                    </div>
                                    <div class="col-12">
                                        <button type="submit" class="btn btn-primary btn-lg w-100 py-3 shadow">Send Message</button>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>
</odoo>