<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_shop_properties" name="Shop Properties">
        <section class="s_shop_properties pt80 pb80">
            <div class="container">
                <div class="d-flex justify-content-between align-items-center mb-5">
                    <div class="">
                        <h2 class="fw-bold">Available Properties</h2>
                        <p class="text-muted">Browse through our selection of available properties.</p>
                    </div>
                    <a href="/shop" class="btn btn-outline-primary">View All Properties</a>
                </div>
                <div class="row g-4">
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm overflow-hidden">
                            <div class="position-relative">
                                <img src="https://www.palazzoia.com/wp-content/uploads/2024/08/Legacy-CX-05.jpg" alt="property-1" class="card-img-top"/>
                                <span class="badge bg-success position-absolute top-0 end-0 m-3">For Sale</span>
                            </div>
                            <div class="card-body">
                                <h5 class="fw-bold">Modern Luxury Villa</h5>
                                <p class="text-muted small"><i class="fa fa-map-marker me-2"></i>Dhaka,Bangladesh</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <h4 class="text-primary mb-0">$250,000</h4>
                                    <a href="/" class="btn btn-sm btn-primary">Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm overflow-hidden">
                            <div class="position-relative">
                                <img src="https://thetelchingroup.com/wp-content/uploads/2021/05/Luxury-home.jpg" alt="property-1" class="card-img-top"/>
                                <span class="badge bg-success position-absolute top-0 end-0 m-3">For Rent</span>
                            </div>
                            <div class="card-body">
                                <h5 class="fw-bold">Cozy Apartment</h5>
                                <p class="text-muted small"><i class="fa fa-map-marker me-2"></i>Chittagong,Bangladesh</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <h4 class="text-primary mb-0">$1,200/mo</h4>
                                    <a href="/" class="btn btn-sm btn-primary">Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-4 col-md-6">
                        <div class="card h-100 border-0 shadow-sm overflow-hidden">
                            <div class="position-relative">
                                <img src="https://img.jamesedition.com/listing_images/2023/11/24/16/07/14/3c10fed8-bb64-4d77-995a-5e353037be13/je/760x470xc.jpg" alt="property-1" class="card-img-top"/>
                                <span class="badge bg-success position-absolute top-0 end-0 m-3">For Sale</span>
                            </div>
                            <div class="card-body">
                                <h5 class="fw-bold">Family Garden House</h5>
                                <p class="text-muted small"><i class="fa fa-map-marker me-2"></i>Sylhet,Bangladesh</p>
                                <div class="d-flex justify-content-between align-items-center mt-3">
                                    <h4 class="text-primary mb-0">$180,000</h4>
                                    <a href="/" class="btn btn-sm btn-primary">Details</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
        
    </template>

</odoo>
