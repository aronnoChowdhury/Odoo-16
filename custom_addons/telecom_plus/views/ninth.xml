<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_ninth" name="Ninth Section">
        <section class="s_ninth py-5">
            <div class="container py-5 rounded-5" style="background-color: #f8fafd;">
                <div class="row g-4 p-4 align-items-center">
                    <div class="col-12 col-lg-6">
                        <img src="https://www.vonage.com/cdn-cgi/image/fit=contain,width=620,f=auto,onerror=redirect/content/dam/vonage/us-en/resources/imagery/article-imagery/SEO-Call-Center-Managment-Blog.jpg" alt="Request a Quote" class="img-fluid rounded-circle"/>
                    </div>
                    <div class="col-12 col-lg-6 p-5" style="background-color: #003061;">
                        <div class="mb-4">
                            <h2 class="display-5 text-danger fw-bold">Request a Quote</h2>
                            <h4 class="fw-semibold text-white mb-3">Tell us what you need</h4>
                            <p class="text-white">Our telecom experts will get back to you with a customized solution</p>
                        </div>
                        <form action="/contactus/submit" class="s_website_form rounded-2" method="post" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <div class="row gap-2">
                                <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <input type="text" name="contact_first_name" required="required" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="First Name"/>
                                </div>
                                <div class="col-md-6">
                                    <input type="text" name="contact_last_name" required="required" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Last Name"/>
                                </div>
                                </div>
                                <div class="col-md-12 mb-2">
                                    <input type="text" name="partner_name" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Company Name"/>
                                </div>
                                <div class="row g-2 mb-2">
                                <div class="col-md-6">
                                    <input type="email" name="contact_email" required="required" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Email Address"/>
                                </div>
                                <div class="col-md-6">
                                    <input type="number" name="contact_phone" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Phone Number"/>
                                </div>
                                </div>
                                <div class="col-md-12 mb-2">
                                    <select name="name" class="form-select py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0">
                                        <option selected="selected" class="text-primary">What Service Do You Need?</option>
                                        <option value="pbx" class="text-primary">Hosted PBX</option>
                                        <option value="voi" class="text-primary">VoIP System</option>
                                        <option value="sip" class="text-primary">SIP Trunking</option>
                                    </select>
                                </div>
                                <div class="col-md-12 mb-2">
                                    <textarea name="description" rows="4" placeholder="Message" id="" class="form-control py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0"></textarea>
                                </div>
                                <div class="mt-2 text-center col-12">
                                    <button class="btn btn-danger py-3 px-4 rounded fw-bold" type="submit">Submit Request</button>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </template>

</odoo>
