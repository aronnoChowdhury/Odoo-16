<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_ninth" name="Ninth Section">
        <section class="s_ninth py-5">
            <div class="container py-5 rounded-5" style="background-color: #f8fafd;">
                <div class="row g-4 p-4 align-items-center">
                    <div class="col-12 col-lg-6">
                        <img src="https://www.vonage.com/cdn-cgi/image/fit=contain,width=620,f=auto,onerror=redirect/content/dam/vonage/us-en/resources/imagery/article-imagery/SEO-Call-Center-Managment-Blog.jpg" alt="Request a Quote" class="img-fluid rounded-circle"/>
                    </div>
                    <div class="col-12 col-lg-6 p-5" style="background-color: #003061;">
                        <div class="mb-4">
                            <h2 class="display-5 text-danger fw-bold">Request a Quote</h2>
                            <h4 class="fw-semibold text-white mb-3">Tell us what you need</h4>
                            <p class="text-white">Our telecom experts will get back to you with a customized solution</p>
                        </div>

                        <div class="s_website_form_end_message d-none">
                            <div class="alert alert-success mt-3 text-center rounded-4">
                                <h4 class="alert-heading">Thank You!</h4>
                                <p class="mb-0">Your message has been sent. We will get back to you soon.</p>
                            </div>
                        </div>
                        <form action="/website/form/" class="s_website_form rounded-2" method="post" data-model_name="crm.lead" data-success-mode="message" enctype="multipart/form-data">
                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                            <span class="s_website_form_result"></span>

                            <div class="row g-3 s_website_form_rows">
                                
                                <div class="col-12 s_website_form_field" data-name="Field" data-type="char">
                                    <input type="text" name="contact_name" required="required" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Full Name"/>
                                </div>
    
                                <div class="col-12 mb-2 s_website_form_field" data-name="Field" data-type="char">
                                    <input type="text" name="partner_name" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Company Name"/>
                                </div>
                                
                                <div class="col-12 mb-2 s_website_form_field" data-name="Field" data-type="char">
                                    <input type="text" name="name" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Subject"/>
                                </div>
                                
                                <div class="col-md-6 s_website_form_field" data-name="Field" data-type="char">
                                    <input type="email" name="email_from" required="required" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Email Address"/>
                                </div>
                                <div class="col-md-6 s_website_form_field" data-name="Field" data-type="char">
                                    <input type="tel" name="phone" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0" placeholder="Phone Number"/>
                                </div>
                                
                                
                                <div class="col-12 mb-2 s_website_form_field" data-type="text" data-name="Field">
                                    <textarea name="description" rows="4" placeholder="Message" id="" class="form-control s_website_form_input py-3 px-4 rounded bg-opacity-10 bg-white text-primary border-0"></textarea>
                                </div>
                                <div class="mt-2 text-center col-12 s_website_form_submit" data-name="Submit Button">
                                    <button class="btn btn-danger s_website_form_send py-3 px-4 rounded fw-bold" type="submit">Submit Request</button>
                                    <span id="s_website_form_result"></span>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </section>
    </template>

</odoo>
