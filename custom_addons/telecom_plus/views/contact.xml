<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_contact_plus" name="Plus Contact">
        <section class="s_contact_plus py-5" style="background-color: #003061;">
            <div class="container py-4">
                <div class="text-center text-white">
                    <h2 class="display-4 fw-bold">Plus Telecom Contact Section</h2>
                    <p class="fw-semibold">Get in Touch With Our Team</p>
                </div>

                <div class="row g-5 mt-4">
                    <div class="col-md-5 text-white">
                        <div class="mb-4">
                            <h4 class="fw-bold text-danger mb-3">Office Address</h4>
                            <p class="text-white"><i class="fa fa-map-marker me-2"></i>123 Telecom Street, Dhaka, Bangladesh</p>
                        </div>
                        <div class="mb-4">
                            <h4 class="fw-bold text-danger mb-3">Quick Contact</h4>
                            <p class="text-white"><i class="fa fa-phone me-2"></i>+880123456789</p>
                            <p class="text-white"><i class="fa fa-envelope me-2"></i>info@telecomplus.com</p>
                        </div>
                        <div class="d-flex gap-3 mt-4">
                            <a href="#" class="btn btn-outline-danger rounded-circle"><i class="fa fa-facebook"></i></a>
                            <a href="#" class="btn btn-outline-danger rounded-circle"><i class="fa fa-twitter"></i></a>
                            <a href="#" class="btn btn-outline-danger rounded-circle"><i class="fa fa-linkedin"></i></a>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="card border-0 rounded-4 shadow-sm p-4 bg-light bg-opacity-10" style="backdrop-filter: blur(10px);">

                            <div class="s_website_form_end_message d-none">
                                <div class="alert alert-success mt-3 text-center rounded-4">
                                    <h4 class="alert-heading">Thank You!</h4>
                                    <p class="mb-0">Your message has been send.We will get back to you soon.</p>
                                </div>
                            </div>

                            <form action="/website/form/" method="post" enctype="multipart/form-data" class="s_website_form" data-model_name="crm.lead" data-success-mode="message">
                                <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()" class=""/>
                                <span class="s_website_form_result"></span>

                                <div class="row g-3 s_website_form_rows">
                                    <div class="col-12 s_website_form_field" data-type="char" data-name="Field">
                                        <input type="text" name="contact_name" class="form-control s_website_form_input bg-transparent py-3 text-danger border-danger" placeholder="Contact Name"/>
                                    </div>
                                    <div class="col-12 s_website_form_field" data-type="char" data-name="Field">
                                        <input type="email" name="email_from" class="form-control s_website_form_input bg-transparent py-3 text-danger border-danger" placeholder="Email Address"/>
                                    </div>
                                    <div class="col-12 s_website_form_field" data-type="char" data-name="Field">
                                        <input type="text" name="name" class="form-control s_website_form_input bg-transparent py-3 text-danger border-danger" placeholder="Subject"/>
                                    </div>
                                    <div class="col-12 s_website_form_field" data-type="char" data-name="Field">
                                        <textarea name="description" rows="4" class="form-control s_website_form_input bg-transparent text-danger border-danger" placeholder="Write your message here..."></textarea>
                                    </div>
                                    <div class="col-12 mt-4">
                                        <button type="submit" class="btn btn-danger s_website_form_send text-white w-100 border-0 rounded-4">Send Message</button>
                                        <span id="s_webiste_form_result"></span>
                                    </div>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>

</odoo>
