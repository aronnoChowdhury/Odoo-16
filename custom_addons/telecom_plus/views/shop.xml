<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="s_shop" name="Plus Shop">
        <section class="s_shop py-5 bg-danger">
            <div class="container py-4">
                <div class="text-center py-4 text-light">
                    <h2 class="display-5 mb-4 fw-bold">Our Featured Product</h2>
                </div>
                <div class="row g-4">
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100 shop-hover">
                            <div class="card-body text-danger">
                                <i class="fa fa-id-card fa-3x mb-3 text-danger"></i>
                                <h5 class="fw-bold">4G Sim Card</h5>
                                <p class="">High-speed connectivity across the nation.</p>
                                <a href="/shop" class="btn btn-outline-danger btn-sm">Buy Now</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100 shop-hover">
                            <div class="card-body text-warning">
                                <i class="fa fa-wifi fa-3x mb-3 text-warning"></i>
                                <h5 class="fw-bold">Plus Router</h5>
                                <p class="">Dual-band high performance router for home and office.</p>
                                <a href="/shop" class="btn btn-outline-warning btn-sm">View Details</a>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="card border-0 shadow-sm h-100 shop-hover">
                            <div class="card-body text-success">
                                <i class="fa fa-database fa-3x mb-3 text-success"></i>
                                <h5 class="fw-bold">Super Data Pack</h5>
                                <p class="">Unlimited data with no speed limits.</p>
                                <a href="/shop" class="btn btn-outline-success btn-sm">Get Offer</a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </template>

</odoo>
